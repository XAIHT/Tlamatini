{
  "mcpServers": {
    "Roblox_Studio": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "%LOCALAPPDATA%\\Roblox\\mcp.bat"
      ]
    },
    "redis": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "REDIS_URL=redis://host.docker.internal:6379",
        "mcp/redis:latest"
      ],
      "env": {},
      "transport": "stdio"
    },
    "octocode": {
      "command": "npx",
      "args": [
        "octocode-mcp"
      ],
      "env": {
        "GITHUB_TOKEN": "<GITHUB_TOKEN goes here>"
      },
      "transport": "stdio"
    },
    "mongodb-lens": {
      "args": [
        "-y",
        "mongodb-lens"
      ],
      "command": "npx",
      "env": {
        "CONFIG_MONGO_URI": "mongodb://localhost:27017"
      },
      "transport": "stdio"
    },
    "Snyk Security Scanner": {
      "command": "snyk",
      "args": [
        "mcp",
        "-t",
        "stdio",
        "--experimental"
      ],
      "env": {
        "API_KEY": "<SNYK_API_KEY goes here>"
      },
      "transport": "stdio"
    }
  },
  "active": [
    "mongodb-lens"
  ]
}