{
  "_comment": "Optimized RAG Configuration for Tlamatini",
  "embeding-model": "bge-m3:latest",
  "chained-model": "glm-5:cloud",
  "access_aimed_prompt_model": "glm-5:cloud",
  "ollama_base_url": "http://127.0.0.1:11434",
  "ollama_token": "",
  "ANTHROPIC_API_KEY": "config you api key here by claude",
  "enable_unified_agent": true,
  "unified_agent_model": "glm-5:cloud",
  "unified_agent_base_url": "http://127.0.0.1:11434",
  "unified_agent_temperature": 0.0,
  "_section_image_interpreter": "Image Interpreter Configuration",
  "image_interpreter_base_url": "http://127.0.0.1:11434",
  "image_interpreter_model": "qwen3.5:cloud",
  "image_interpreter_temperature": 0,
  "image_interpreter_image_path": "",
  "_section_mcp": "MCP System Configuration",
  "mcp_system_server_host": "127.0.0.1",
  "mcp_system_server_port": 8765,
  "mcp_system_client_uri": "ws://127.0.0.1:8765",
  "mcp_files_search_server_host": "localhost",
  "mcp_files_search_server_port": 50051,
  "mcp_files_search_server_max_workers": 10,
  "mcp_files_search_model": "glm-5:cloud",
  "mcp_files_search_client_uri": "ws://127.0.0.1:50051",
  "max_lines_search_files": 1024,
  "_section_internet": "Internet Search Configuration",
  "internet_classifier_model": "glm-5:cloud",
  "internet_classifier_verbose": true,
  "internet_classifier_max_iterations": 4,
  "internet_classifier_streaming": true,
  "internet_hint_words_mode": "extend",
  "internet_hint_words": [],
  "web_summarizer_model": "glm-5:cloud",
  "web_context_max_chars": 10000,
  "web_search_tool_name": "web_search",
  "web_search_tool_description": "A tool for searching the internet for current events, real-time information, or facts you do not know.",
  "_section_chunking": "Document Chunking - OPTIMIZED FOR CODE",
  "chunk_size": 3000,
  "_chunk_size_comment": "INCREASED to 3000 - Capture full methods/classes",
  "chunk_overlap": 800,
  "_chunk_overlap_comment": "INCREASED to 800 - Ensure continuity between chunks",
  "max_chunks_per_file": 50,
  "_max_chunks_per_file_comment": "INCREASED to 50 - Virtually unlimited chunks per file",
  "_section_retrieval": "Retrieval Configuration - OPTIMIZED FOR RECALL",
  "use_mmr": false,
  "_use_mmr_comment": "DISABLED - Standard similarity is better for finding all relevant code pieces",
  "k_vector": 100,
  "_k_vector_comment": "INCREASED to 100 - Deep semantic search",
  "fetch_k": 300,
  "_fetch_k_comment": "INCREASED to 300 - Large candidate pool",
  "mmr_lambda": 0.7,
  "enable_bm25": true,
  "_enable_bm25_comment": "ENABLED - Critical for keyword matching (function names, etc.)",
  "k_bm25": 100,
  "_k_bm25_comment": "INCREASED to 100 - Match k_vector for balance",
  "rrf_k": 60,
  "k_fused": 150,
  "_k_fused_comment": "INCREASED to 150 - Return a huge amount of context",
  "_section_compression": "Context Compression - OPTIMIZED",
  "use_llm_extractor": true,
  "use_embeddings_filter": false,
  "embeddings_filter_threshold": 0.4,
  "use_long_context_reorder": true,
  "_section_context_limits": "Context Size Limits - OPTIMIZED",
  "max_doc_chars": 150000,
  "_max_doc_chars_comment": "INCREASED to 150k - Allow very large files",
  "max_context_chars": 250000,
  "_max_context_chars_comment": "INCREASED to 250k - Fill large context window",
  "_section_context_budget": "Context Budget Allocation",
  "context_budget_allocation": {
    "high_relevance": 0.60,
    "architecture": 0.20,
    "related": 0.15,
    "documentation": 0.05
  },
  "_context_budget_comment": "Prioritize high relevance (60%) and architecture (20%)",
  "_section_security": "Security",
  "redact_secrets_in_context": true,
  "_section_history": "Chat History Management",
  "history_summary_enable": true,
  "history_summary_trigger_tokens": 150,
  "history_keep_last_turns": 3,
  "_section_metadata": "Metadata Extraction",
  "metadata_extraction": {
    "enable_code_structure": true,
    "enable_file_role_classification": true,
    "enable_dependency_tracking": true,
    "enable_cross_references": true
  },
  "_section_retrieval_strategy": "Advanced Retrieval Strategy",
  "retrieval_strategy": {
    "enable_multi_stage": false,
    "_enable_multi_stage_comment": "DISABLED - Use standard RRF (Vector + BM25) for better code recall",
    "enable_query_expansion": true,
    "enable_hierarchical_context": true,
    "enable_context_budget_allocation": true
  },
  "_section_misc": "Miscellaneous Settings",
  "load_hidden": true,
  "ssl_verify": false,
  "disable_proxies": false,
  "max_input_tokens": 5000,
  "keep_last_turns": 3,
  "ssl_cert_file": "",
  "requests_ca_bundle": "",
  "_section_performance": "Performance Tuning",
  "performance": {
    "enable_caching": true,
    "cache_embeddings": true,
    "parallel_processing": true,
    "max_workers": 12
  },
  "_section_logging": "Logging Configuration",
  "logging": {
    "log_retrieval_metrics": true,
    "log_context_size": true,
    "log_query_rewrites": true,
    "verbose_metadata": true
  },
  "allowed_paths": [
    "application",
    "docs",
    "downloads",
    "desktop",
    "pictures",
    "videos",
    "music"
  ]
}