# Local secrets vault used by regen_secrets.py — NEVER commit
data.keys

# External MCP catalog — USER STATE, may hold live API tokens — NEVER commit
Tlamatini/agent/external_mcps.json

# Versioning — generated by build.py from git tags; see VERSIONING.md.
# _version.py is regenerated on every build and embedded in the frozen
# bundle; the three *.version.txt files are transient PyInstaller inputs
# that the build scripts clean up themselves, but ignore them anyway in
# case a build aborts mid-run.
Tlamatini/agent/_version.py
Tlamatini.version.txt
Installer.version.txt
Uninstaller.version.txt

# Build concurrency lock (build.py)
.build.lock

# Source-tree build Python — a standalone, writable Python 3.12.10 kept at
# <repo>/python, auto-provisioned by build.py (ensure_local_build_python) as the
# CARRIED-Python source: deps install into ITS writable prefix (never Program Files)
# and bundle_carried_python copytrees it into <dist>/python complete. Large, local,
# regenerable build artifact — never commit. Delete it to force a clean re-provision.
/python/

# Tlamatini Temp directory — the SOLE runtime temporary dir (pinned by
# manage.py / settings.py to <app-root>/Temp). Created on demand at the repo
# root (source mode) and next to the .exe (frozen). Pure transient state —
# never commit its contents. See agent/path_guard.py + prompt.pmt Rule 15.
/Temp/
Tlamatini/Temp/

# Tlamatini Templates directory — the DEFAULT home for template/firmware/engine
# projects the STM32er/ESP32er/Arduiner/Unrealer agents scaffold (exported as
# TLAMATINI_TEMPLATES; ships empty next to the .exe). Generated project trees
# are user output, not repo content — never commit them. See prompt.pmt Rule 16.
/Templates/
Tlamatini/Templates/
# Private contacts book (names / phone numbers / messaging handles).
# PII — must NEVER be committed. Scrubbed from history 2026-06-25.
Tlamatini/agent/contacts.json
/Tlamatini/agent/contacts.json
contacts.json

# Private-data audit artifacts — may contain personal data; never commit
personal_info_audit_report.md
private_data_audit_report.json
.private_targets.json
